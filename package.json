{
  "name": "traceback-ai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "traceback": "./dist/cli.js"
  },
  "scripts": {
    "traceback": "bun src/cli.ts",
    "build": "bun build ./src/cli.ts --outdir ./dist --target bun && bun scripts/make-executable.ts dist/cli.js",
    "check": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "commander": "^14.0.2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.3",
    "typescript": "^5.9.3"
  },
  "engines": {
    "bun": ">=1.2.0"
  }
}
